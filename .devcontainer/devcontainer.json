{
  "name": "User Management - Spring Boot",
  "image": "mcr.microsoft.com/devcontainers/java:17",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/postgresql:1": {
      "version": "16",
      "installPsql": true
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vscjava.vscode-maven",
        "vscjava.vscode-spring-boot-dashboard",
        "vscjava.vscode-lombok",
        "ms-azuretools.vscode-docker",
        "eamodio.gitlens",
        "sonarsource.sonarlint-vscode",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "java.home": "/usr/lib/jvm/java-17-openjdk",
        "java.configuration.updateBuildConfiguration": "interactive",
        "maven.executable.preferMavenWrapper": true,
        "[java]": {
          "editor.defaultFormatter": "redhat.java",
          "editor.formatOnSave": true
        },
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": false
        }
      }
    }
  },
  "postCreateCommand": "mvn clean install -DskipTests",
  "postStartCommand": "mvn clean package -DskipTests",
  "containerEnv": {
    "BD_URL": "jdbc:postgresql://db:5432/user_management_db?ssl=false",
    "DB_USERNAME": "developer",
    "DB_PASSWORD": "devjava2026",
    "PORT": "8181"
  },
  "forwardPorts": [8181, 5432],
  "portsAttributes": {
    "8181": {
      "label": "Application",
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    }
  },
  "remoteUser": "vscode",
  "mounts": [
    "source=${localEnv:HOME}/.m2,target=/home/vscode/.m2,type=bind,consistency=cached"
  ],
  "service": "app"
}
