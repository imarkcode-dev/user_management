{
  "name": "User Management - Spring Boot",
  "image": "mcr.microsoft.com/devcontainers/java:17",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Extension Pack for Java",
        "vscjava.vscode-maven",
        "vscjava.vscode-spring-boot-dashboard",
        "vscjava.vscode-lombok",
        "ms-azuretools.vscode-docker",
        "eamodio.gitlens",
        "sonarsource.sonarlint-vscode",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "java.home": "/usr/lib/jvm/java-17-openjdk",
        "java.configuration.updateBuildConfiguration": "interactive",
        "maven.executable.preferMavenWrapper": true,
        "[java]": {
          "editor.defaultFormatter": "redhat.java",
          "editor.formatOnSave": true
        },
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": false
        }
      }
    }
  },
  "postCreateCommand": "mvn clean install -DskipTests",
  "postStartCommand": "mvn clean package -DskipTests",
  "containerEnv": {
     "BD_URL": "jdbc:postgresql://db:5432/user_management_db?ssl=false}",
     "DB_USERNAME": "developer",
     "DB_PASSWORD": "devjava2026",
     "PORT": "8181"
  },
  "services": {
    "db": {
        "image": "postgres:17",
        "restart": "always",
        "enviroment": {
            "POSTGRESQL_USER": "developer",
            "POSTGRESQL_PASSWORD": "devjava2026",
            "POSTGRESQL_DB": "user_management_db"
        },
     "ports":["5432:5432"]
    }
  },
  "forwardPorts": [8181, 5432],
  "portsAttributes": {
    "8181": {
      "label": "Application",
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    }
  },
  "remoteUser": "vscode",
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.m2,target=/home/vscode/.m2,type=bind,consistency=cached"
  ]
}
